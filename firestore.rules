rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: workers
    // Fields:
    //   - name: string (required)
    //   - chairNumber: number (required)
    //   - commissionRate: number (required)
    //   - isActive: bool (optional)
    //   - createdAt: timestamp (optional)
    //
    // Collection: materials
    // Fields:
    //   - name: string (required)
    //   - price: number (required)
    //   - stock: number (required)
    //   - unit: string (optional)
    //
    // Collection: invoices
    // Fields:
    //   - customerName: string (required)
    //   - workerId: string (required)
    //   - materialsUsed: list (required)
    //   - servicePrice: number (required)
    //   - totalAmount: number (required)
    //   - workerShare: number (required)
    //   - profit: number (required)
    //   - timestamp: timestamp (required)
    //
    // Collection: expenses
    // Fields:
    //   - description: string (required)
    //   - amount: number (required)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "mnamhoon@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidWorker(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.chairNumber is number && data.chairNumber >= 0 &&
             data.commissionRate is number && data.commissionRate >= 0 && data.commissionRate <= 1;
    }

    function isValidMaterial(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.purchasePrice is number && data.purchasePrice >= 0 &&
             data.sellingPrice is number && data.sellingPrice >= 0 &&
             data.stock is number && data.stock >= 0;
    }

    function isValidPayment(data) {
      return data.workerId is string &&
             data.amount is number && data.amount > 0 &&
             data.timestamp is timestamp &&
             data.type == 'payment';
    }

    function isValidInvoice(data) {
      return data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.workerId is string &&
             data.materialsUsed is list &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.workerShare is number && data.workerShare >= 0 &&
             data.profit is number && data.profit >= 0 &&
             data.timestamp is timestamp;
    }

    function isValidExpense(data) {
      return data.description is string && data.description.size() > 0 && data.description.size() < 500 &&
             data.amount is number && data.amount >= 0 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /workers/{workerId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() && (request.method == 'delete' || isValidWorker(request.resource.data));
    }

    match /materials/{materialId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() && (request.method == 'delete' || isValidMaterial(request.resource.data));
    }

    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidInvoice(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPayment(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidExpense(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
